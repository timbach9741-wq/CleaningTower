rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 파트너 로고 — 누구나 읽기, 인증된 사용자만 업로드
    match /partner_logos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 파트너 포트폴리오 — 누구나 읽기, 인증된 사용자만 업로드
    match /partner_portfolio/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 기타 모든 경로 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
